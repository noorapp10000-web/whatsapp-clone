# Flutter/Dart
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
*.g.dart
*.freezed.dart

# Android - sensitive/generated files (keep gradle wrapper & google-services in repo)
**/android/.gradle
**/android/captures/
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java
**/android/key.properties
# Keystores — but allow the committed debug keystore
**/*.keystore
!android/app/debug.keystore
**/*.jks

# Firebase config is committed intentionally (non-secret, needed for CI build)
# **/google-services.json   ← intentionally NOT ignored

# Misc
*.log
pubspec.lock
